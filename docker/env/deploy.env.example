# Copy this file to docker/env/<environment>.env and update the values for the target host.

# Docker project/network
COMPOSE_PROJECT_NAME=beskar-prod
DOCKER_NETWORK_NAME=beskar-network

# Public domains
TLS_ENABLED=true
APP_DOMAIN=app.example.com
AUTH_DOMAIN=id.example.com
LANDING_DOMAIN=www.example.com

# TLS files on the deployment host
TLS_CERT_PATH=/opt/beskar/certs/fullchain.pem
TLS_KEY_PATH=/opt/beskar/certs/privkey.pem

# Published proxy ports
PROXY_HTTP_PORT=80
PROXY_HTTPS_PORT=443

# Optional derived public URLs. These default automatically if left unset.
PUBLIC_BASE_URL=
AUTH_PUBLIC_URL=
LANDING_PUBLIC_URL=
NEXTAUTH_URL=
NEXTAUTH_URL_INTERNAL=
NEXT_PUBLIC_USER_SERVER_URL=
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_API_BASE_URL=
NEXT_PUBLIC_IMAGE_SERVER_URL=
NEXT_PUBLIC_SIGNALING_URL=
NEXT_PUBLIC_HASURA_PROJECT_ENDPOINT=
BESKAR_SERVER_URL=
CORS_ALLOWED_ORIGINS=

# UI/Next.js runtime secrets
NEXTAUTH_SECRET=replace-with-a-long-random-secret

# GitHub Packages token used to build the production UI image.
NPM_TOKEN=replace-with-github-packages-token

# Database configuration
DB_HOST=postgres
DB_PORT=5432
POSTGRES_DATA_MOUNT=postgres_data:/var/lib/postgresql/data
DB_ROOT_DB=postgres
DB_ROOT_USER=admin
DB_ROOT_PASS=replace-with-postgres-root-password
DB_APP_NAME=beskar
DB_AUTH_NAME=auth
DB_ZITADEL_NAME=zitadel
DB_ADMIN_USERNAME=beskar_admin
DB_ADMIN_PASSWORD=replace-with-beskar-admin-password
DB_APP_USERNAME=beskar_app
DB_APP_PASSWORD=replace-with-beskar-app-password

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=replace-with-redis-password

# Permify
PERMIFY_ENDPOINT=guard:3478
PERMIFY_SECRET=replace-with-permify-secret

# Zitadel
ZITADEL_MASTER_KEY=replace-with-32-byte-master-key
ZITADEL_ISSUER_URL=
ZITADEL_EXTERNALDOMAIN=
ZITADEL_EXTERNALSECURE=
ZITADEL_ADMIN_USERNAME=admin
ZITADEL_ADMIN_PASSWORD=replace-with-zitadel-admin-password
ZITADEL_CLIENT_ID=replace-with-zitadel-client-id
ZITADEL_CLIENT_SECRET=replace-with-zitadel-client-secret
ZITADEL_USER_PAT=replace-with-zitadel-user-pat
