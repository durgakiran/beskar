server {
    listen 80;
    server_name {{APP_DOMAIN}} {{AUTH_DOMAIN}} {{LANDING_DOMAIN}};

    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl;
    server_name {{APP_DOMAIN}};

    ssl_certificate /etc/nginx/ssl/tls.crt;
    ssl_certificate_key /etc/nginx/ssl/tls.key;
    client_max_body_size 200M;
    resolver 127.0.0.11 ipv6=off;

    location / {
        set $ui_upstream http://ui:3000;
        proxy_pass $ui_upstream;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Cookie $http_cookie;
        proxy_cookie_flags ~ nosecure SameSite=Lax;
    }

    location /auth {
        set $server_upstream http://server:9095;
        proxy_pass $server_upstream;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Cookie $http_cookie;
        proxy_cookie_flags ~ nosecure SameSite=Lax;
    }

    location /api/v1 {
        set $server_upstream http://server:9095;
        proxy_pass $server_upstream;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Cookie $http_cookie;
        proxy_cookie_flags ~ nosecure SameSite=Lax;
    }

    location /ws {
        set $signal_upstream http://signalserver:8080/ws;
        proxy_pass $signal_upstream;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Cookie $http_cookie;
        proxy_cookie_flags ~ nosecure SameSite=Lax;
    }
}

server {
    listen 443 ssl;
    server_name {{AUTH_DOMAIN}};

    ssl_certificate /etc/nginx/ssl/tls.crt;
    ssl_certificate_key /etc/nginx/ssl/tls.key;
    resolver 127.0.0.11 ipv6=off;

    location / {
        set $zitadel_upstream http://zitadel:8080;
        proxy_pass $zitadel_upstream;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Authorization $http_authorization;
        proxy_set_header Cookie $http_cookie;
        proxy_pass_header Authorization;
    }
}

server {
    listen 443 ssl;
    server_name {{LANDING_DOMAIN}};

    ssl_certificate /etc/nginx/ssl/tls.crt;
    ssl_certificate_key /etc/nginx/ssl/tls.key;
    client_max_body_size 50M;
    resolver 127.0.0.11 ipv6=off;

    location / {
        set $launchsite_upstream http://launchsite:3001;
        proxy_pass $launchsite_upstream;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
