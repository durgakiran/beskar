services:
  postgres:
    image: postgres:16.2-alpine3.19
    restart: unless-stopped
    environment:
      POSTGRES_DB: {{DB_ROOT_DB}}
      POSTGRES_USER: {{DB_ROOT_USER}}
      POSTGRES_PASSWORD: {{DB_ROOT_PASS}}
    volumes:
      - {{POSTGRES_DATA_MOUNT}}
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -h localhost -p 5432 -U {{DB_ROOT_USER}}"]
      interval: 5s
      timeout: 5s
      retries: 20
    networks:
      - app_net

  db-init:
    build:
      context: ../..
      dockerfile: docker/deploy/db-init.Dockerfile
    environment:
      DB_HOST: {{DB_HOST}}
      DB_PORT: {{DB_PORT}}
      DB_ROOT: {{DB_ROOT_DB}}
      DB_ROOT_USER: {{DB_ROOT_USER}}
      DB_ROOT_PASS: {{DB_ROOT_PASS}}
      DB_APP_NAME: {{DB_APP_NAME}}
      DB_AUTH_NAME: {{DB_AUTH_NAME}}
      DB_BESKAR_ADMIN_USER: {{DB_ADMIN_USERNAME}}
      DB_BESKAR_ADMIN_USER_PWD: {{DB_ADMIN_PASSWORD}}
      DB_BESKAR_APP_USER: {{DB_APP_USERNAME}}
      DB_BESKAR_APP_USER_PWD: {{DB_APP_PASSWORD}}
    depends_on:
      postgres:
        condition: service_healthy
    networks:
      - app_net

  redis:
    image: redis:7-alpine
    restart: unless-stopped
    command: redis-server --requirepass {{REDIS_PASSWORD}} --appendonly yes --loglevel notice
    volumes:
      - redis_data:/data
    healthcheck:
      test: ["CMD", "redis-cli", "-a", "{{REDIS_PASSWORD}}", "ping"]
      interval: 10s
      timeout: 5s
      retries: 10
    networks:
      - app_net

  guard:
    image: ghcr.io/permify/permify
    restart: unless-stopped
    environment:
      PERMIFY_DATABASE_ENGINE: postgres
      PERMIFY_DATABASE_URI: postgres://{{DB_ADMIN_USERNAME}}:{{DB_ADMIN_PASSWORD}}@postgres:5432/{{DB_AUTH_NAME}}
      PERMIFY_DATABASE_AUTO_MIGRATE: "true"
      PERMIFY_DATABASE_MAX_OPEN_CONNECTIONS: "20"
      PERMIFY_AUTHN_ENABLED: "true"
      PERMIFY_AUTHN_METHOD: preshared
      PERMIFY_AUTHN_PRESHARED_KEYS: {{PERMIFY_SECRET}}
      PERMIFY_LOGGER_LEVEL: info
      PERMIFY_SERVER_RATE_LIMIT: "100"
      PERMIFY_SERVER_HTTP_ENABLED: "true"
      PERMIFY_SERVER_HTTP_PORT: "3476"
      PERMIFY_SERVER_HTTP_TLS_ENABLED: "false"
      PERMIFY_SERVER_GRPS_PORT: "3478"
      PERMIFY_SERVER_GRPC_TLS_ENABLED: "false"
      PERMIFY_LOG_ENABLED: "false"
    depends_on:
      postgres:
        condition: service_healthy
    networks:
      - app_net

  zitadel:
    image: {{ZITADEL_IMAGE}}
    restart: unless-stopped
    command: start-from-init --masterkey "{{ZITADEL_MASTER_KEY}}" --tlsMode external
    environment:
      ZITADEL_EXTERNALDOMAIN: {{ZITADEL_EXTERNALDOMAIN}}
      ZITADEL_LOGSTORE_ACCESS_STDOUT_ENABLED: "true"
      ZITADEL_DATABASE_POSTGRES_HOST: postgres
      ZITADEL_DATABASE_POSTGRES_PORT: "5432"
      ZITADEL_DATABASE_POSTGRES_DATABASE: {{DB_ZITADEL_NAME}}
      ZITADEL_DATABASE_POSTGRES_USER_USERNAME: {{DB_ADMIN_USERNAME}}
      ZITADEL_DATABASE_POSTGRES_USER_PASSWORD: "{{DB_ADMIN_PASSWORD}}"
      ZITADEL_DATABASE_POSTGRES_USER_SSL_MODE: disable
      ZITADEL_DATABASE_POSTGRES_ADMIN_USERNAME: {{DB_ROOT_USER}}
      ZITADEL_DATABASE_POSTGRES_ADMIN_PASSWORD: "{{DB_ROOT_PASS}}"
      ZITADEL_DATABASE_POSTGRES_ADMIN_SSL_MODE: disable
      ZITADEL_EXTERNALSECURE: {{ZITADEL_EXTERNALSECURE}}
      ZITADEL_DEFAULTINSTANCE_FEATURES_LOGINV2_REQUIRED: "{{ZITADEL_LOGIN_V2_REQUIRED}}"
      ZITADEL_FIRSTINSTANCE_ORG_HUMAN_USERNAME: {{ZITADEL_ADMIN_USERNAME}}
      ZITADEL_FIRSTINSTANCE_ORG_HUMAN_PASSWORD: "{{ZITADEL_ADMIN_PASSWORD}}"
    depends_on:
      postgres:
        condition: service_healthy
    networks:
      - app_net

  ui:
    build:
      context: ../..
      dockerfile: docker/deploy/ui.Dockerfile
      args:
        NPM_TOKEN: {{NPM_TOKEN}}
        NEXTAUTH_URL: {{NEXTAUTH_URL}}
        NEXTAUTH_URL_INTERNAL: {{NEXTAUTH_URL_INTERNAL}}
        NEXTAUTH_SECRET: {{NEXTAUTH_SECRET}}
        NEXT_PUBLIC_USER_SERVER_URL: {{NEXT_PUBLIC_USER_SERVER_URL}}
        NEXT_PUBLIC_API_URL: {{NEXT_PUBLIC_API_URL}}
        NEXT_PUBLIC_API_BASE_URL: {{NEXT_PUBLIC_API_BASE_URL}}
        NEXT_PUBLIC_IMAGE_SERVER_URL: {{NEXT_PUBLIC_IMAGE_SERVER_URL}}
        NEXT_PUBLIC_SIGNALING_URL: {{NEXT_PUBLIC_SIGNALING_URL}}
        NEXT_PUBLIC_HASURA_PROJECT_ENDPOINT: {{NEXT_PUBLIC_HASURA_PROJECT_ENDPOINT}}
    restart: unless-stopped
    environment:
      NODE_ENV: production
      PORT: "3000"
      NEXTAUTH_URL: {{NEXTAUTH_URL}}
      NEXTAUTH_URL_INTERNAL: {{NEXTAUTH_URL_INTERNAL}}
      NEXTAUTH_SECRET: {{NEXTAUTH_SECRET}}
      NEXT_PUBLIC_USER_SERVER_URL: {{NEXT_PUBLIC_USER_SERVER_URL}}
      NEXT_PUBLIC_API_URL: {{NEXT_PUBLIC_API_URL}}
      NEXT_PUBLIC_API_BASE_URL: {{NEXT_PUBLIC_API_BASE_URL}}
      NEXT_PUBLIC_IMAGE_SERVER_URL: {{NEXT_PUBLIC_IMAGE_SERVER_URL}}
      NEXT_PUBLIC_SIGNALING_URL: {{NEXT_PUBLIC_SIGNALING_URL}}
      NEXT_PUBLIC_HASURA_PROJECT_ENDPOINT: {{NEXT_PUBLIC_HASURA_PROJECT_ENDPOINT}}
    expose:
      - "3000"
    networks:
      - app_net

  launchsite:
    build:
      context: ../..
      dockerfile: docker/app/launchsite/Dockerfile
    restart: unless-stopped
    environment:
      NODE_ENV: production
      NEXT_TELEMETRY_DISABLED: "1"
    expose:
      - "3001"
    healthcheck:
      test: ["CMD-SHELL", "wget --spider -q http://localhost:3001/ || exit 1"]
      interval: 20s
      timeout: 10s
      retries: 6
    networks:
      - app_net

  server:
    build:
      context: ../..
      dockerfile: docker/deploy/server.Dockerfile
    restart: unless-stopped
    environment:
      PG_HOST: {{DB_HOST}}
      PG_PORT: {{DB_PORT}}
      PG_DB: {{DB_APP_NAME}}
      PG_USER: {{DB_APP_USERNAME}}
      PG_PASSWORD: {{DB_APP_PASSWORD}}
      PERMIFY_ENDPOINT: {{PERMIFY_ENDPOINT}}
      PERMIFY_SECRET: {{PERMIFY_SECRET}}
      ISSUER_URL: {{ZITADEL_ISSUER_URL}}
      CLIENT_ID: {{ZITADEL_CLIENT_ID}}
      SERVER_PAT: {{ZITADEL_USER_PAT}}
      KEY: {{ZITADEL_CLIENT_SECRET}}
      SERVER_URL: {{BESKAR_SERVER_URL}}
      ZITADEL_REGISTRATION_ORG_ID: {{ZITADEL_REGISTRATION_ORG_ID}}
      INSECURE_SKIP_VERIFY: "{{INSECURE_SKIP_VERIFY}}"
      CORS_ALLOWED_ORIGINS: {{CORS_ALLOWED_ORIGINS}}
      UPLOAD_STORAGE_DIR: {{UPLOAD_STORAGE_DIR}}
      EMAIL_NOTIFICATIONS_ENABLED: "{{EMAIL_NOTIFICATIONS_ENABLED}}"
      EMAIL_WORKER_ENABLED: "{{EMAIL_WORKER_ENABLED}}"
      EMAIL_ADMIN_ENABLED: "{{EMAIL_ADMIN_ENABLED}}"
      EMAIL_ADMIN_TOKEN: {{EMAIL_ADMIN_TOKEN}}
      EMAIL_PROVIDER: {{EMAIL_PROVIDER}}
      EMAIL_FROM_ADDRESS: {{EMAIL_FROM_ADDRESS}}
      EMAIL_FROM_NAME: {{EMAIL_FROM_NAME}}
      EMAIL_APP_BASE_URL: {{EMAIL_APP_BASE_URL}}
      SMTP_HOST: {{SMTP_HOST}}
      SMTP_PORT: "{{SMTP_PORT}}"
      SMTP_USERNAME: {{SMTP_USERNAME}}
      SMTP_PASSWORD: {{SMTP_PASSWORD}}
      SMTP_USE_TLS: "{{SMTP_USE_TLS}}"
      SMTP_TIMEOUT_SECONDS: "{{SMTP_TIMEOUT_SECONDS}}"
      EMAIL_WORKER_POLL_INTERVAL_SECONDS: "{{EMAIL_WORKER_POLL_INTERVAL_SECONDS}}"
      EMAIL_WORKER_BATCH_SIZE: "{{EMAIL_WORKER_BATCH_SIZE}}"
      EMAIL_MAX_ATTEMPTS: "{{EMAIL_MAX_ATTEMPTS}}"
      EMAIL_RETRY_INITIAL_SECONDS: "{{EMAIL_RETRY_INITIAL_SECONDS}}"
      EMAIL_RETRY_MAX_SECONDS: "{{EMAIL_RETRY_MAX_SECONDS}}"
    depends_on:
      postgres:
        condition: service_healthy
      guard:
        condition: service_started
      zitadel:
        condition: service_started
    expose:
      - "9095"
    healthcheck:
      test: ["CMD-SHELL", "wget --spider -q http://localhost:9095/ || exit 1"]
      interval: 20s
      timeout: 10s
      retries: 6
    networks:
      - app_net

  signalserver:
    build:
      context: ../..
      dockerfile: docker/deploy/signalserver.Dockerfile
    restart: unless-stopped
    environment:
      AUTH_SERVER_URL: http://server:9095
      CORS_ALLOWED_ORIGINS: {{CORS_ALLOWED_ORIGINS}}
    depends_on:
      server:
        condition: service_started
    expose:
      - "8080"
    healthcheck:
      test: ["CMD-SHELL", "wget --spider -q http://localhost:8080/ || exit 1"]
      interval: 20s
      timeout: 10s
      retries: 6
    networks:
      - app_net

  proxy:
    image: nginx:1.24
    restart: unless-stopped
    ports:
      - "{{PROXY_HTTP_PORT}}:80"
    volumes:
      - ./nginx/default.conf:/etc/nginx/conf.d/default.conf:ro
    healthcheck:
      test: ["CMD-SHELL", "service nginx status || exit 1"]
      interval: 5s
      timeout: 3s
      retries: 5
{{PROXY_NETWORKS_BLOCK}}

networks:
  app_net:
    name: {{DOCKER_NETWORK_NAME}}

volumes:
  postgres_data:
  redis_data:
