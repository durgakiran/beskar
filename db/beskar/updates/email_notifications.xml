<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns:ext="http://www.liquibase.org/xml/ns/dbchangelog-ext"
    xmlns:pro="http://www.liquibase.org/xml/ns/pro"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd
                        http://www.liquibase.org/xml/ns/dbchangelog-ext http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-ext.xsd
                        http://www.liquibase.org/xml/ns/pro http://www.liquibase.org/xml/ns/pro/liquibase-pro-latest.xsd">

    <changeSet id="1-create-email-messages-table" author="OpenAI">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists schemaName="notifications" tableName="email_messages"/>
            </not>
        </preConditions>
        <createTable tableName="email_messages" schemaName="notifications">
            <column name="id" type="UUID" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="message_key" type="TEXT">
                <constraints nullable="false" unique="true" uniqueConstraintName="email_messages_message_key_key"/>
            </column>
            <column name="category" type="TEXT">
                <constraints nullable="false"/>
            </column>
            <column name="template_key" type="TEXT">
                <constraints nullable="false"/>
            </column>
            <column name="template_version" type="TEXT"/>
            <column name="recipient_user_id" type="UUID"/>
            <column name="recipient_email" type="TEXT">
                <constraints nullable="false"/>
            </column>
            <column name="recipient_name" type="TEXT"/>
            <column name="subject" type="TEXT"/>
            <column name="text_body" type="TEXT"/>
            <column name="html_body" type="TEXT"/>
            <column name="template_data" type="JSONB" defaultValueComputed="'{}'::jsonb">
                <constraints nullable="false"/>
            </column>
            <column name="priority" type="TEXT" defaultValue="normal">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="TEXT" defaultValue="pending">
                <constraints nullable="false"/>
            </column>
            <column name="attempt_count" type="INT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="scheduled_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
            <column name="next_attempt_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
            <column name="last_attempt_at" type="TIMESTAMP WITH TIME ZONE"/>
            <column name="sent_at" type="TIMESTAMP WITH TIME ZONE"/>
            <column name="failed_at" type="TIMESTAMP WITH TIME ZONE"/>
            <column name="dead_lettered_at" type="TIMESTAMP WITH TIME ZONE"/>
            <column name="provider" type="TEXT"/>
            <column name="provider_message_id" type="TEXT"/>
            <column name="last_error_code" type="TEXT"/>
            <column name="last_error_message" type="TEXT"/>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <rollback>
            <dropTable tableName="email_messages" schemaName="notifications"/>
        </rollback>
    </changeSet>

    <changeSet id="2-create-email-delivery-attempts-table" author="OpenAI">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists schemaName="notifications" tableName="email_delivery_attempts"/>
            </not>
        </preConditions>
        <createTable tableName="email_delivery_attempts" schemaName="notifications">
            <column name="id" type="UUID" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="email_message_id" type="UUID">
                <constraints nullable="false" foreignKeyName="email_delivery_attempts_message_fkey"
                    references="notifications.email_messages(id)" deleteCascade="true"/>
            </column>
            <column name="attempt_number" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="provider" type="TEXT">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="TEXT">
                <constraints nullable="false"/>
            </column>
            <column name="started_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
            <column name="finished_at" type="TIMESTAMP WITH TIME ZONE"/>
            <column name="provider_message_id" type="TEXT"/>
            <column name="error_code" type="TEXT"/>
            <column name="error_message" type="TEXT"/>
        </createTable>
        <rollback>
            <dropTable tableName="email_delivery_attempts" schemaName="notifications"/>
        </rollback>
    </changeSet>

    <changeSet id="3-create-email-preferences-table" author="OpenAI">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists schemaName="notifications" tableName="email_preferences"/>
            </not>
        </preConditions>
        <createTable tableName="email_preferences" schemaName="notifications">
            <column name="recipient_user_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="category" type="TEXT">
                <constraints nullable="false"/>
            </column>
            <column name="enabled" type="BOOLEAN" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
            <column name="frequency" type="TEXT" defaultValue="instant">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addPrimaryKey schemaName="notifications" tableName="email_preferences"
            columnNames="recipient_user_id, category" constraintName="email_preferences_pkey"/>
        <rollback>
            <dropTable tableName="email_preferences" schemaName="notifications"/>
        </rollback>
    </changeSet>

    <changeSet id="4-create-email-suppressions-table" author="OpenAI">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists schemaName="notifications" tableName="email_suppressions"/>
            </not>
        </preConditions>
        <createTable tableName="email_suppressions" schemaName="notifications">
            <column name="email" type="TEXT">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="reason" type="TEXT">
                <constraints nullable="false"/>
            </column>
            <column name="source" type="TEXT">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <rollback>
            <dropTable tableName="email_suppressions" schemaName="notifications"/>
        </rollback>
    </changeSet>

    <changeSet id="5-create-email-notification-indexes" author="OpenAI">
        <preConditions onFail="MARK_RAN">
            <not>
                <indexExists schemaName="notifications" tableName="email_messages" indexName="idx_email_messages_worker_lookup"/>
            </not>
        </preConditions>
        <createIndex schemaName="notifications" tableName="email_messages" indexName="idx_email_messages_worker_lookup">
            <column name="status"/>
            <column name="next_attempt_at"/>
            <column name="priority"/>
        </createIndex>
        <createIndex schemaName="notifications" tableName="email_messages" indexName="idx_email_messages_recipient_user_created_at">
            <column name="recipient_user_id"/>
            <column name="created_at" descending="true"/>
        </createIndex>
        <createIndex schemaName="notifications" tableName="email_messages" indexName="idx_email_messages_recipient_email_created_at">
            <column name="recipient_email"/>
            <column name="created_at" descending="true"/>
        </createIndex>
        <createIndex schemaName="notifications" tableName="email_delivery_attempts" indexName="idx_email_delivery_attempts_message_attempt">
            <column name="email_message_id"/>
            <column name="attempt_number" descending="true"/>
        </createIndex>
        <rollback>
            <dropIndex schemaName="notifications" tableName="email_messages" indexName="idx_email_messages_worker_lookup"/>
            <dropIndex schemaName="notifications" tableName="email_messages" indexName="idx_email_messages_recipient_user_created_at"/>
            <dropIndex schemaName="notifications" tableName="email_messages" indexName="idx_email_messages_recipient_email_created_at"/>
            <dropIndex schemaName="notifications" tableName="email_delivery_attempts" indexName="idx_email_delivery_attempts_message_attempt"/>
        </rollback>
    </changeSet>

    <changeSet id="6-grant-email-notification-privileges" author="OpenAI">
        <sql>
            GRANT SELECT, INSERT, UPDATE, DELETE ON notifications.email_messages TO ${app_user};
            GRANT SELECT, INSERT, UPDATE, DELETE ON notifications.email_delivery_attempts TO ${app_user};
            GRANT SELECT, INSERT, UPDATE, DELETE ON notifications.email_preferences TO ${app_user};
            GRANT SELECT, INSERT, UPDATE, DELETE ON notifications.email_suppressions TO ${app_user};
        </sql>
        <rollback/>
    </changeSet>
</databaseChangeLog>
