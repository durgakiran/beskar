<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns:ext="http://www.liquibase.org/xml/ns/dbchangelog-ext"
    xmlns:pro="http://www.liquibase.org/xml/ns/pro"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd
                        http://www.liquibase.org/xml/ns/dbchangelog-ext http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-ext.xsd
                        http://www.liquibase.org/xml/ns/pro http://www.liquibase.org/xml/ns/pro/liquibase-pro-latest.xsd">

    <changeSet id="1-create-attachment-table" author="Kiran Kumar">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">
                SELECT COUNT(*) FROM information_schema.tables WHERE table_name = 'attachment' AND table_schema = 'core';
            </sqlCheck>
        </preConditions>
        <comment>Create attachment table for inline file references in documents</comment>
        <createTable tableName="attachment" schemaName="core">
            <column name="id" type="UUID" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="page_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <!-- Relative path on disk, e.g. public/attachments/report-abc123de.pdf -->
            <column name="storage_path" type="TEXT">
                <constraints nullable="false"/>
            </column>
            <!-- Sanitized display name shown in the chip and Content-Disposition header -->
            <column name="file_name" type="TEXT">
                <constraints nullable="false"/>
            </column>
            <column name="file_size" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="mime_type" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <!-- Zitadel subject claim of the uploading user -->
            <column name="created_by" type="TEXT">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
            <!-- Soft-delete timestamp; NULL = active. Used by the orphan cleanup job. -->
            <column name="deleted_at" type="TIMESTAMP WITH TIME ZONE"/>
        </createTable>
        <rollback>
            <dropTable tableName="attachment" schemaName="core"/>
        </rollback>
    </changeSet>

    <changeSet id="2-attachment-page-fkey" author="Kiran Kumar">
        <comment>Foreign key: attachment.page_id → core.page.id (cascade on page delete)</comment>
        <addForeignKeyConstraint
            baseTableName="attachment" baseTableSchemaName="core" baseColumnNames="page_id"
            constraintName="attachment_page_id_fkey"
            referencedTableName="page" referencedTableSchemaName="core" referencedColumnNames="id"
            deleteCascade="true"/>
        <rollback>
            <dropForeignKeyConstraint baseTableName="attachment" baseTableSchemaName="core" constraintName="attachment_page_id_fkey"/>
        </rollback>
    </changeSet>

    <changeSet id="3-attachment-page-id-index" author="Kiran Kumar">
        <comment>Index on page_id for efficient per-page attachment queries and orphan cleanup scans</comment>
        <createIndex tableName="attachment" schemaName="core" indexName="idx_attachment_page_id">
            <column name="page_id"/>
        </createIndex>
        <rollback>
            <dropIndex tableName="attachment" schemaName="core" indexName="idx_attachment_page_id"/>
        </rollback>
    </changeSet>

    <changeSet id="4-grant-attachment-privileges" author="Kiran Kumar">
        <comment>Grant SELECT, INSERT, UPDATE, DELETE on attachment table to app user</comment>
        <sql>
            GRANT SELECT, INSERT, UPDATE, DELETE ON core.attachment TO ${app_user};
        </sql>
        <rollback/>
    </changeSet>

</databaseChangeLog>
