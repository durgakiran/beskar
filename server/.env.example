KC_REALM_URL=http://localhost:8083/realms/devbeskarrealm
KC_CLIENT_ID=besarappclient

# Email notification engine
EMAIL_NOTIFICATIONS_ENABLED=true
EMAIL_WORKER_ENABLED=true
EMAIL_ADMIN_ENABLED=true
EMAIL_ADMIN_TOKEN=local-email-admin-token
EMAIL_PROVIDER=smtp
EMAIL_FROM_ADDRESS=
EMAIL_FROM_NAME=Beskar
EMAIL_APP_BASE_URL=http://localhost:3000
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_TIMEOUT_SECONDS=10
EMAIL_WORKER_POLL_INTERVAL_SECONDS=10
EMAIL_WORKER_BATCH_SIZE=25
EMAIL_MAX_ATTEMPTS=10
EMAIL_RETRY_INITIAL_SECONDS=30
EMAIL_RETRY_MAX_SECONDS=21600
