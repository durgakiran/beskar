                  "type": "frame",
                  "id": "NotifMobItem3",
                  "width": "fill_container",
                  "fill": "$color.accent.3",
                  "layout": "vertical",
                  "gap": 4,
                  "padding": 14,
                  "children": [
                    {
                      "type": "frame",
                      "id": "NotifMobItem3Head",
                      "gap": 10,
                      "children": [
                        {
                          "type": "ellipse",
                          "id": "NotifMobItem3Dot",
                          "fill": "$color.brand.primary",
                          "width": 10,
                          "height": 10
                        },
                        {
                          "type": "frame",
                          "id": "NotifMobItem3Copy",
                          "layout": "vertical",
                          "gap": 4,
                          "children": [
                            {
                              "type": "text",
                              "id": "NotifMobItem3T",
                              "fill": "$color.text.default",
                              "textGrowth": "fixed-width",
                              "width": 300,
                              "content": "Ownership transferred in Sprint Planning",
                              "fontFamily": "Inter",
                              "fontSize": 14,
                              "fontWeight": "700"
                            },
