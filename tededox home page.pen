                      "fontSize": 11,
                      "fontWeight": "600"
                    },
                    {
                      "type": "text",
                      "id": "NotifMobEmpty1T",
                      "fill": "$color.text.default",
                      "content": "No notifications need your attention",
                      "fontFamily": "Inter",
                      "fontSize": 14,
                      "fontWeight": "700"
                    },
                    {
                      "type": "text",
                      "id": "NotifMobEmpty1D",
