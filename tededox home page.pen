                    "thickness": 1,
                    "fill": "$color.border.default"
                  },
                  "layout": "vertical",
                  "gap": 6,
                  "padding": 14,
                  "children": [
                    {
                      "type": "text",
                      "id": "NotifMobToast1L",
                      "fill": "$color.text.muted",
                      "content": "After Accept",
                      "fontFamily": "Inter",
                      "fontSize": 11,
                      "fontWeight": "600"
                    },
                    {
                      "type": "text",
                      "id": "NotifMobToast1T",
                      "fill": "$color.text.default",
                      "content": "Invite accepted",
                      "fontFamily": "Inter",
                      "fontSize": 14,
                      "fontWeight": "700"
                    },
                    {
                      "type": "text",
                      "id": "NotifMobToast1D",
                      "fill": "$color.text.subtle",
                      "content": "The invite becomes read and keeps an Open space action.",
                      "fontFamily": "Inter",
                      "fontSize": 12,
                      "fontWeight": "500"
                    }
                  ]
                },
                {
